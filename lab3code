# csa.py

import random
from objective import fitness_function

# Initialize population
def initialize_population(size):
    return [random.uniform(-5, 5) for _ in range(size)]

# Select best antibodies
def select_best(population, num_best):
    sorted_pop = sorted(population, key=fitness_function, reverse=True)
    return sorted_pop[:num_best]

# Clone antibodies
def clone_population(selected, clone_factor):
    clones = []
    for antibody in selected:
        for _ in range(clone_factor):
            clones.append(antibody)
    return clones

# Mutation
def mutate(clones, mutation_rate):
    mutated = []
    for c in clones:
        if random.random() < mutation_rate:
            c = c + random.uniform(-1, 1)
        mutated.append(c)
    return mutated

# Replace worst with new antibodies
def replace(population, new_population):
    combined = population + new_population
    combined_sorted = sorted(combined, key=fitness_function, reverse=True)
    return combined_sorted[:len(population)]

# Main CSA Function
def clonal_selection(pop_size, generations, clone_factor, mutation_rate):

    # Step 1: Initialize
    population = initialize_population(pop_size)

    for gen in range(generations):
        print(f"\nGeneration {gen+1}")
        print("Population:", population)

        # Step 2: Select best
        selected = select_best(population, pop_size // 2)

        # Step 3: Clone
        clones = clone_population(selected, clone_factor)

        # Step 4: Mutate
        mutated_clones = mutate(clones, mutation_rate)

        # Step 5: Replace
        population = replace(population, mutated_clones)

        # Print best
        best = max(population, key=fitness_function)
        print("Best:", best, "Fitness:", fitness_function(best))

    return population

